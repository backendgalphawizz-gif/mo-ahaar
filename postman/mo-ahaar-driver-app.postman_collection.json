    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications (grouped)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "let list = j.data && j.data.notifications ? j.data.notifications : [];",
                  "if (j.data && j.data.groups) {",
                  "    list = j.data.groups.flatMap(function (g) { return g.notifications || []; });",
                  "}",
                  "if (list.length && list[0].notification_id) {",
                  "    pm.collectionVariables.set('notification_id', String(list[0].notification_id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
