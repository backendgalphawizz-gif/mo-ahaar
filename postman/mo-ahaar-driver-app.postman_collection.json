    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const list = json.data && json.data.notifications ? json.data.notifications : [];",
                  "if (list.length && list[0].notification_id) {",
                  "    pm.collectionVariables.set('notification_id', String(list[0].notification_id));",
                  "}"
                ]
              }
            }
