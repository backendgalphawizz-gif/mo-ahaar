{
  "info": {
    "_postman_id": "8a7f0c8f-2f91-4f1f-b9a9-7b4f0f9aa101",
    "name": "Customer Promo APIs",
    "description": "List and apply promo APIs for customer app.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Promo - List Available",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/customer-app/promo/list?order_amount={{orderAmount}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "customer-app",
            "promo",
            "list"
          ],
          "query": [
            {
              "key": "order_amount",
              "value": "{{orderAmount}}"
            }
          ]
        }
      }
    },
    {
      "name": "Promo - Apply",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"{{promoCode}}\",\n  \"order_amount\": {{orderAmount}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/customer-app/promo/apply",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "customer-app",
            "promo",
            "apply"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://192.168.1.10:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "orderAmount",
      "value": "999"
    },
    {
      "key": "promoCode",
      "value": "TRIVAGO"
    }
  ]
}
