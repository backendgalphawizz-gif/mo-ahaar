    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": { "method": "GET", "url": "{{base_url}}/customer-app/cart" }
        },
        {
          "name": "Add To Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
