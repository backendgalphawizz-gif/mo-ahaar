            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Shreya Shah\",\n  \"mobile_number\": \"9517530286\",\n  \"house_no_building_name\": \"G - 14 1st\",\n  \"road_name_area_colony\": \"Sabari Nagar, Sukhliya\",\n  \"city\": \"Indore\",\n  \"state\": \"M.P\",\n  \"country\": \"India\",\n  \"pincode\": \"452001\",\n  \"delivery_type\": \"home\"\n}"
            },
            "url": "{{base_url}}/customer-app/addresses/{{address_id}}"
