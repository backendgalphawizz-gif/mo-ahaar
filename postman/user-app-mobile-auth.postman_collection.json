{
  "info": {
    "_postman_id": "f7f3a59d-8f52-4a9f-a0be-5d9b9dd7f910",
    "name": "Mo Ahaar - User App",
    "description": "Customer / user mobile app APIs. Run Login → Verify OTP first; token is saved automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Login - Request OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"{{mobile}}\"\n}"
            },
            "url": "{{base_url}}/user-app/login"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json?.otp) pm.collectionVariables.set('otp', String(json.otp));",
                "if (json?.token) pm.collectionVariables.set('token', String(json.token));"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "2. Login - Verify OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": "{{base_url}}/user-app/verify-otp"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json?.token) pm.collectionVariables.set('token', String(json.token));"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/customer-app/auth/logout"
          }
        },
        {
          "name": "Registration Content (Privacy, Terms, FAQ)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/customer-app/auth/registration-content"
          }
        }
      ]
    },
    {
      "name": "Settings & Content",
      "item": [
        {
          "name": "Business Settings (Profile support pages)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/customer-app/settings/business"
          }
        }
      ]
    },
    {
      "name": "Home & Discovery",
      "item": [
        {
          "name": "Home Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Dashboard response now includes `featured_products[].review_count` for each featured food item.",
            "url": {
              "raw": "{{base_url}}/customer-app/home/dashboard?latitude={{latitude}}&longitude={{longitude}}",
              "host": ["{{base_url}}"],
              "path": ["customer-app", "home", "dashboard"],
              "query": [
                { "key": "latitude", "value": "{{latitude}}" },
                { "key": "longitude", "value": "{{longitude}}" }
              ]
            }
          }
        },
        {
          "name": "Search (Foods & Restaurants)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/customer-app/products/search?q={{search_query}}",
              "host": ["{{base_url}}"],
              "path": ["customer-app", "products", "search"],
              "query": [{ "key": "q", "value": "{{search_query}}" }]
            }
          }
        },
        {
          "name": "Categories List",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/customer-app/products/categories"
          }
        },
        {
          "name": "Category Products (e.g. Pizza)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/customer-app/products/categories/{{category_id}}"
          }
        },
        {
          "name": "Product Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/customer-app/products/detail/{{product_id}}"
          }
        },
        {
          "name": "Nearby Restaurants",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/customer-app/vendors/nearby?latitude={{latitude}}&longitude={{longitude}}",
              "host": ["{{base_url}}"],
              "path": ["customer-app", "vendors", "nearby"],
              "query": [
                { "key": "latitude", "value": "{{latitude}}" },
                { "key": "longitude", "value": "{{longitude}}" }
              ]
            }
          }
        },
        {
          "name": "Restaurant Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/customer-app/vendors/{{vendor_id}}"
          }
        },
        {
          "name": "Restaurant Menu",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/customer-app/vendors/{{vendor_id}}/menu?category_id=&is_veg=",
              "host": ["{{base_url}}"],
              "path": ["customer-app", "vendors", "{{vendor_id}}", "menu"]
            }
          }
        },
        {
          "name": "Enable Location",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": {{latitude}},\n  \"longitude\": {{longitude}}\n}"
            },
            "url": "{{base_url}}/customer-app/location/enable"
          }
        }
      ]
    },
    {
